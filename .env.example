BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET=  # generate with: openssl rand -hex 32

# GitHub OAuth App (for user login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (for webhooks + API actions)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# GitHub App slug for installation URL (the name in github.com/apps/{slug})
VITE_GITHUB_APP_SLUG=tripwire-dev

# Dev-only UI tooling (only applies when vite is in development mode).
# Values: true/false or 1/0 (strings). Omit or false = disabled.
# VITE_REACT_SCAN_ENABLED=true
# VITE_REACT_GRAB_ENABLED=true

# Optional in local dev. Leave blank to use file-backed PGlite at .tripwire/pglite.
# Required in production.
DATABASE_URL=

# Unkey rate limiting (optional - allows all requests if not set)
UNKEY_ROOT_KEY=

# Autumn billing
AUTUMN_SECRET_KEY=

# Axiom — used for both evlog wide events and OpenTelemetry traces.
# Create two datasets in Axiom: one for events (logs), one for traces.
AXIOM_TOKEN=
AXIOM_DATASET=
AXIOM_TRACES_DATASET=

# OpenTelemetry traces — set the endpoint to your Axiom edge domain.
# e.g. https://api.axiom.co  (the SDK appends /v1/traces automatically)
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co
# Optional: extra headers as "K1=V1,K2=V2". AXIOM_TOKEN and AXIOM_TRACES_DATASET
# above are wired automatically, so this only needs to be set for non-Axiom backends.
OTEL_EXPORTER_OTLP_HEADERS=

# Trace sampling. Defaults to AlwaysOn (every trace exported). When volume
# becomes a concern, switch to `parentbased_traceidratio` and set the ratio.
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1   # keep 10% of root traces

# Inngest — durable background jobs (research runs, future async work).
# In local dev: leave blank and run `npx inngest-cli dev` for the dev proxy.
# In prod: grab keys from https://app.inngest.com.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Branch environment name. Required when your event/signing keys belong to a
# branch env (not "production") — otherwise Inngest returns
# "400 Branch environment name is required". Leave blank for production.
# Example: INNGEST_ENV=staging  or  INNGEST_ENV=preview-pr-42
INNGEST_ENV=

# Research eval harness — admin tool that runs the signal pipeline against
# thousands of GitHub contributors to build a labeled dataset for ML / research.
# Uses a Personal Access Token (NOT the GitHub App) so it can read PR data
# from any public repo, whether the GH App is installed there or not.
# Needs `public_repo` scope. Create at https://github.com/settings/tokens.
RESEARCH_GH_TOKEN=
